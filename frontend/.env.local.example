# ============================================================
# Environment Variables untuk ZKP Auth System
# ============================================================
# Copy file ini menjadi .env.local dan isi nilainya

# Address smart contract ZKPAuthSystem (setelah deploy ke Sepolia)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_ISI_SETELAH_DEPLOY

# Untuk deploy contract (jangan commit ke git!)
PRIVATE_KEY=0x_PRIVATE_KEY_WALLET_KAMU
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETHERSCAN_API_KEY=ISI_API_KEY_ETHERSCAN
